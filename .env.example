# Environment Variables - Copy to .env and fill in values

# Database
POSTGRES_USER=cuthuay
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=cuthuay
DATABASE_URL=postgresql://cuthuay:change_this_strong_password@localhost:5432/cuthuay

# JWT — generate: openssl rand -base64 48 (min 32 chars; never use example in production)
JWT_SECRET=change_this_to_a_very_long_random_string_min_64_chars
JWT_EXPIRES_IN=8h

# Dev seed only (backend npm run seed) — omit to auto-generate one-time passwords in logs
SEED_ADMIN_PASSWORD=
SEED_OPERATOR_PASSWORD=
SEED_VIEWER_PASSWORD=

# Phase 6: dual httpOnly cookie + bearer (LAN: keep false until HTTPS reverse proxy)
COOKIE_AUTH_ENABLED=false
# Phase 2: require X-CSRF-Token on mutations (requires COOKIE_AUTH_ENABLED=true)
CSRF_ENABLED=false
# Secure cookie flag — default true in production; false only for HTTP LAN pilot
# COOKIE_SECURE=false

# PDPA audit_log retention (default off / dry-run)
# PDPA_PURGE_ENABLED=false
# PDPA_PURGE_DRY_RUN=true
# AUDIT_LOG_RETENTION_DAYS=90

# Frontend — enable with backend flags for staging pilot
# NEXT_PUBLIC_COOKIE_AUTH_ENABLED=true
# NEXT_PUBLIC_CSRF_ENABLED=true

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Reports output directory
REPORTS_DIR=./reports

# ── Docker (npm run docker:up) ────────────────────────────────────────────────
# ค่า POSTGRES_* / JWT_SECRET ถูกอ่านโดย docker-compose.yml
# Postgres ใน Docker เปิดที่ host port 5433 (กันชน DB บนเครื่องที่พอร์ต 5432)
# POSTGRES_HOST_PORT=5433
# ถ้า build backend บน Mac ไม่ผ่าน (Paddle): ตั้ง DOCKER_PLATFORM=linux/amd64
# DOCKER_PLATFORM=linux/amd64
