# Environment Variables - Copy to .env and fill in values

# Database
POSTGRES_USER=cuthuay
POSTGRES_PASSWORD=change_this_strong_password
POSTGRES_DB=cuthuay
DATABASE_URL=postgresql://cuthuay:change_this_strong_password@localhost:5432/cuthuay

# JWT
JWT_SECRET=change_this_to_a_very_long_random_string_min_64_chars
JWT_EXPIRES_IN=8h

# Server
PORT=4000
NODE_ENV=development
CORS_ORIGIN=http://localhost:3000

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:4000/api
NEXT_PUBLIC_WS_URL=ws://localhost:4000

# Reports output directory
REPORTS_DIR=./reports

# ─── OCR รูปโพย (POST /bets/ocr-image) ─────────────────────────────────────
# ไฟล์ .env ควรอยู่ที่โฟลเดอร์ backend/ — API โหลดจากที่นี่เสมอ (ไม่พึ่ง cwd ตอนรัน npm)
# Google Cloud Vision — บนเครื่อง dev ต้องชี้ไฟล์ JSON ของ service account
# (ถ้าไม่ตั้ง จะได้ error เรื่อง default credentials — ตั้งค่าตามบรรทัดด้านล่าง)
# รัน backend จากโฟลเดอร์ backend แล้วใช้ path สัมพันธ์กับ cwd นั้น
# Google Cloud Vision: path ไฟล์ JSON ของ service account (ห้าม commit ไฟล์นี้)
# GOOGLE_APPLICATION_CREDENTIALS=./secrets/vision-api-key.json
# หรือระบุแยก (override)
# GOOGLE_VISION_KEY_FILE=./secrets/vision-api-key.json
# บน Cloud Run / GCE ที่แนบ service account (ไม่มีไฟล์ JSON ในเครื่อง)
# GOOGLE_VISION_USE_ADC=1
# ลำดับโหมดอัตโนมัติจากฟอร์ม — ค่าเริ่ม Paddle แล้ว Google Vision (ประหยัดโควตา Vision)
# ค่าเริ่มบน API: paddle,google-vision (โควตาฟรี Vision ~1000 รูป/เดือน แล้วคิดเงินตาม GCP)
# OCR_IMAGE_AUTO_ORDER=paddle,google-vision
#
# PaddleOCR: Python + backend/scripts/paddle_ocr_image.py
# PADDLE_OCR_PYTHON=python3
# PADDLE_OCR_TIMEOUT_MS=120000

# ─── Docker Compose (ไฟล์ .env ข้าง docker-compose.yml) ─────────────────────
# backend โหลด JSON จาก mount: ./backend/secrets → /app/secrets
# GOOGLE_APPLICATION_CREDENTIALS=/app/secrets/vision-key.json
# (ค่าเริ่มใน docker-compose.yml ตั้งไว้แล้ว — แค่ให้มีไฟล์ vision-key.json ใน backend/secrets บน host)
