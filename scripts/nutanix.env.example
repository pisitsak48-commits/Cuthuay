# คัดลอกเป็น .env ที่ root โปรเจกต์บนเซิร์ฟ (หรือให้ deploy-nutanix.sh สร้างครั้งแรกให้)
# แก้ POSTGRES_PASSWORD และ JWT_SECRET ให้เป็นค่าจริงก่อนใช้งานจริง

POSTGRES_USER=cuthuay
POSTGRES_PASSWORD=change_this_postgres_password
POSTGRES_DB=cuthuay

JWT_SECRET=replace_with_openssl_rand_base64_48_or_longer_secret_string
JWT_EXPIRES_IN=8h

# URL ที่เบราว์เซอร์เปิดหน้าเว็บ (พอร์ต 3000) — ให้ตรงกับที่พิมพ์ใน address bar
CORS_ORIGIN=http://192.168.101.198:3000

# REST API ผ่าน Next.js proxy ที่ /api แล้ว — ไม่ต้องตั้ง NEXT_PUBLIC_API_URL
# WebSocket ใช้พอร์ต 4000 บน host เดียวกับที่เปิดเว็บ (อัตโนมัติ)
