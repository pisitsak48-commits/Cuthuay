# คัดลอกเป็น scripts/deploy.local.env (ไม่ commit)
#   cp scripts/deploy.local.env.example scripts/deploy.local.env
#
# กรณีคุณ: แก้โค้ดในโฟลเดอร์ Mac ชื่อ AuraX → deploy ขึ้นเซิร์ฟโฟลเดอร์ Cut Huay เดิม

SERVER=nutanix-linux@192.168.101.198
REMOTE_PATH="/home/nutanix-linux/Cut Huay"

# โฟลเดอร์บน Mac — ว่าง = ใช้ที่รันสคริปต์ (/Users/.../AuraX)
# LOCAL_PATH=/Users/kruepet.pisitsak/AuraX

# เซิร์ฟรันอยู่แล้ว มี .env แล้ว — อย่าเปิด ENSURE_ENV (จะไม่ทับ .env อยู่แล้วถ้าไม่มีไฟล์)
ENSURE_ENV=false

# ทดสอบก่อน sync จริง:
# DRY_RUN=true

# build เร็วขึ้น (ใช้ cache) — ครั้งแรกหลังแก้ Dockerfile ควรปิดไว้
# BUILD_CACHE=true
